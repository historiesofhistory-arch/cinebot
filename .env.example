# ── Required ──────────────────────────────────────────────────────────────────
# Get from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=

# Full URL where the app is hosted — bot uses this in watch links
# e.g. https://your-app.onrender.com/cinebot-app/
PLAYER_URL=

# ── Optional ──────────────────────────────────────────────────────────────────
# Free key from https://www.themoviedb.org/settings/api
# Only needed for /trending, /popular, /popular_series, /genres
# All search commands work WITHOUT this key (uses free IMDB API instead)
TMDB_API_KEY=

# HTTP port — defaults to 8080 (Render sets this to 10000 automatically)
# PORT=8080
